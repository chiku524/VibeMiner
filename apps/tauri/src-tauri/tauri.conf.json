{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeMiner",
  "version": "1.0.63",
  "identifier": "com.nicobuilds.vibeminer",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": null,
    "frontendDist": "../../web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "VibeMiner",
        "url": "/",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "title": "VibeMiner",
        "url": "/desktop/splash",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
