{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeMiner",
  "version": "1.0.59",
  "identifier": "com.nicobuilds.vibeminer",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": {
      "script": "node scripts/prepare-frontend-dist.cjs",
      "cwd": ".."
    },
    "frontendDist": "../../web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VibeMiner",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Mine for networks that need you. No terminal required.",
    "shortDescription": "One-click crypto mining and node running",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Finance"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
