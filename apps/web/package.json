{
  "name": "vibeminer-web",
  "version": "1.0.88",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "generate-brand-assets": "node scripts/build-brand-assets.cjs",
    "generate-seo-assets": "node scripts/build-brand-assets.cjs",
    "prebuild": "node scripts/build-brand-assets.cjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "preview": "node ./scripts/opennext-clean.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node ./scripts/opennext-clean.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:ensure-node-presets-json": "node ./scripts/d1-ensure-node-presets-json.mjs",
    "db:ensure-node-presets-json:local": "node ./scripts/d1-ensure-node-presets-json.mjs --local"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@opennextjs/cloudflare": "^1.0.0",
    "@vibeminer/shared": "*",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.77.0"
  }
}
